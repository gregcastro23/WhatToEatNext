#!/bin/sh
# git-lfs pre-push: warn if lfs is missing but don't block the push,
# since most pushes contain only code (no tracked binary files).
if ! command -v git-lfs >/dev/null 2>&1; then
  printf >&2 "\nWarning: git-lfs not found — skipping LFS pre-push check.\nInstall git-lfs if you need to push large binary assets.\n\n"
  exit 0
fi
git lfs pre-push "$@"
