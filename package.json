    "lint:fast": "eslint --config eslint.config.mjs --cache --cache-location .eslintcache src",
    "lint:quick": "eslint --config eslint.config.fast.mjs src --cache --cache-location .eslintcache-fast --max-warnings=10000",
    "lint:type-aware": "eslint --config eslint.config.mjs src --max-warnings=10000",
    "lint:incremental": "eslint --config eslint.config.fast.mjs --cache $(git diff --name-only --diff-filter=ACMR HEAD | grep -E '\\.(ts|tsx|js|jsx)$' | tr '\\n' ' ')",
    "lint:changed": "eslint --config eslint.config.mjs --cache $(git diff --name-only --diff-filter=ACMR HEAD | grep -E '\\.(ts|tsx|js|jsx)$' | tr '\\n' ' ')",
    "lint:performance": "time eslint --config eslint.config.mjs src --format=json --output-file=.eslint-results.json",
    "lint:profile": "TIMING=1 eslint --config eslint.config.fast.mjs src --format=json --output-file=.eslint-profile.json",
    "lint:parallel": "eslint --config eslint.config.mjs src --max-warnings=10000 --cache",
    "lint:ci": "eslint --config eslint.config.fast.mjs src --format=stylish --max-warnings=10000",
