  "scripts": {
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build": "next build",
    "build:pwa": "ENABLE_PWA=true NEXT_PUBLIC_ENABLE_PWA=true next build",
    "build:size-check": "next build && bun scripts/check-route-sizes.cjs",
