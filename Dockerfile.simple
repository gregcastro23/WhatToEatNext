# Simple Dockerfile for development
FROM node:25-alpine

WORKDIR /app

# Enable corepack and install dependencies
RUN corepack enable
COPY package.json bun.lock .bunrc ./
RUN bun install

# Copy source
COPY . .

# Build the app
RUN bun run build

# Expose port
EXPOSE 3000

# Health check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:3000/api/health || exit 1

# Start
CMD ["bun", "start"]