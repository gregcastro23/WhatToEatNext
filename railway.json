{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "backend/Dockerfile"
  },
  "deploy": {
    "startCommand": "uvicorn alchm_kitchen.main:app --host 0.0.0.0 --port $PORT",
    "numReplicas": 1,
    "restartPolicyType": "ON_FAILURE"
  }
}
