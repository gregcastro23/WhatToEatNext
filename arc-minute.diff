new file mode 100644
index 000000000..b729b2027
--- /dev/null
+++ b/src/fix-all-tolowercase.js
@@ -0,0 +1,35 @@
+const fs = require('fs');
+
+const files = [
+  'src/data/cuisineFlavorProfiles.ts',
+  'src/components/IngredientRecommender.tsx',
+  'src/components/IngredientRecommender/index.tsx',
+  'src/utils/recipeMatching.ts'
+];
+
+files.forEach(filePath => {
+  if (fs.existsSync(filePath)) {
+    let content = fs.readFileSync(filePath, 'utf8');
+    
+    // Fix the specific error pattern
+    content = content.replace(
+      /\.some$$\s*(\w+)\s*=>\s*\1\.toLowerCase\($$\.includes/g,
+      '.some($1 => $1 && typeof $1 === "string" && $1.toLowerCase().includes'
+    );
+    
+    content = content.replace(
+      /\.filter$$\s*(\w+)\s*=>\s*\1\.toLowerCase\($$\.includes/g,
+      '.filter($1 => $1 && typeof $1 === "string" && $1.toLowerCase().includes'
+    );
+    
+    content = content.replace(
+      /\.some$$\s*(\w+)\s*=>\s*\1\.toLowerCase\($$\s*===/g,
+      '.some($1 => $1 && typeof $1 === "string" && $1.toLowerCase() ==='
+    );
+    
+    fs.writeFileSync(filePath, content);
+    console.log(`Fixed ${filePath}`);
+  } else {
+    console.log(`File not found: ${filePath}`);
+  }
+});
diff --git a/src/fix-tolowercase-error.js b/src/fix-tolowercase-error.js
new file mode 100644
index 000000000..4c0c8532a
--- /dev/null
+++ b/src/fix-tolowercase-error.js
@@ -0,0 +1,26 @@
+const fs = require('fs');
+
+// Read the ingredient recommender file
+const filePath = 'src/utils/ingredientRecommender.ts';
+let content = fs.readFileSync(filePath, 'utf8');
+
+// Fix all unsafe toLowerCase patterns
+content = content.replace(
+  /(\w+)\.toLowerCase$$$$/g,
+  '($1 && typeof $1 === "string" ? $1.toLowerCase() : "")'
+);
+
+// Fix specific patterns that cause the error
+content = content.replace(
+  /\.some$$\s*(\w+)\s*=>\s*\(\1 && typeof \1 === "string" \? \1\.toLowerCase\($$ : ""\)\.includes/g,
+  '.some($1 => $1 && typeof $1 === "string" && $1.toLowerCase().includes'
+);
+
+content = content.replace(
+  /\.filter$$\s*(\w+)\s*=>\s*\(\1 && typeof \1 === "string" \? \1\.toLowerCase\($$ : ""\)\.includes/g,
+  '.filter($1 => $1 && typeof $1 === "string" && $1.toLowerCase().includes'
+);
+
+// Write the fixed content back
+fs.writeFileSync(filePath, content);
+console.log('Fixed ingredientRecommender.ts');
