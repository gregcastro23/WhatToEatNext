# WhatToEatNext Environment Configuration
# Copy this file to .env.local for development or .env.production for production

# ============================================================================
# GENERAL CONFIGURATION
# ============================================================================

# Do NOT set NODE_ENV here — Next.js sets it automatically (development in `next dev`, production in `next build`).
# Setting it manually causes a Next.js warning and can break CSS/PostCSS compilation in dev.
# NODE_ENV=development

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# NEXT.JS CONFIGURATION
# ============================================================================

# Disable Next.js telemetry
NEXT_TELEMETRY_DISABLED=1

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Internal API Base URL (for server-side requests)
# Leave empty to use relative paths
API_BASE_URL=

# External API timeout (milliseconds)
API_TIMEOUT=10000

# Python Backend URL for Swiss Ephemeris calculations
# Development: http://localhost:8000
# Production: Set to your deployed backend URL (e.g., https://backend.railway.app)
BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# Cloudflare -> Vercel proxy target for lightweight Worker routes.
# Required when deploying the Cloudflare proxy build.
VERCEL_API_URL=

# Shared secret used for trusted internal calls between frontend/worker/backend.
INTERNAL_API_SECRET=

# Optional public Cloudflare Worker base URL used by edge-aware client helpers.
NEXT_PUBLIC_CLOUDFLARE_WORKER_URL=

# Optional public image CDN/custom domain. Leave empty to serve R2 objects
# through /api/assets so private buckets do not expose 401 bucket pages.
NEXT_PUBLIC_ASSET_DOMAIN=

# Cloudflare R2 private asset storage. Required by /api/assets when
# NEXT_PUBLIC_ASSET_DOMAIN is empty.
CLOUDFLARE_ACCOUNT_ID=
R2_BUCKET_NAME=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Optional direct Hyperdrive connection URL for Cloudflare runtime database access.
HYPERDRIVE_URL=

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================

# Auth.js (NextAuth v5) secret for signing tokens and cookies
# Generate with: bunx auth secret  OR  openssl rand -base64 32
# REQUIRED for production. Preview deployments degrade gracefully without it.
AUTH_SECRET=your-auth-secret-here-change-in-production

# Canonical URL of the application (used to construct OAuth redirect URIs)
# Development: http://localhost:3000
# Production:  https://alchm.kitchen  (or your deployed domain)
AUTH_URL=http://localhost:3000

# Trust the Host header (required for non-Vercel deployments)
AUTH_TRUST_HOST=true

# Google OAuth credentials (for Auth.js Google provider)
# Create at: https://console.cloud.google.com/apis/credentials
#   Authorized JavaScript origins:  http://localhost:3000
#   Authorized redirect URIs:       http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id
AUTH_GOOGLE_SECRET=your-google-client-secret

# Admin email - first user with this email gets ADMIN role automatically
AUTH_ADMIN_EMAIL=xalchm@gmail.com

# Soft session revocation gate. Set to "on" to make middleware check
# every protected-route request against the device_sessions revocation
# store (Upstash Redis denylist + Postgres fallback). Defaults to off
# so the feature can be deployed and observed before being enabled.
# See docs/adr/004-device-sessions.md.
AUTH_REVOCATION_CHECK=off

# Optional override for the negative-cache TTL written to Redis on
# revocation lookup. Defaults to 30 days to match the JWT maxAge in
# src/lib/auth/auth.config.ts. Keep these in sync.
# AUTH_JWT_MAX_AGE_SECONDS=2592000

# JWT Secret for legacy session management
# Generate with: openssl rand -base64 32
JWT_SECRET=your-secret-key-here-change-in-production

# Session cookie settings
SESSION_COOKIE_NAME=alchm_session
SESSION_MAX_AGE=86400

# CORS allowed origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://alchm.kitchen

# ============================================================================
# DATABASE CONFIGURATION (if needed)
# ============================================================================

# PostgreSQL connection string
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Connection pool settings
# DB_POOL_MIN=2
# DB_POOL_MAX=10

# ============================================================================
# CACHE & REDIS (if needed)
# ============================================================================

# Redis connection URL
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=your-redis-password

# Cache TTL (seconds)
CACHE_TTL=60

# ============================================================================
# LOGGING & MONITORING
# ============================================================================

# Log level (debug | info | warn | error | silent)
LOG_LEVEL=info

# Enable console logging
LOG_CONSOLE_ENABLED=true

# Enable file logging
LOG_FILE_ENABLED=false
LOG_FILE_PATH=./logs

# Sentry DSN (for error tracking)
# SENTRY_DSN=https://your-sentry-dsn

# ============================================================================
# PLANETARY CALCULATIONS
# ============================================================================

# Default location for astrological calculations (New York)
DEFAULT_LATITUDE=40.7498
DEFAULT_LONGITUDE=-73.7976
DEFAULT_TIMEZONE=America/New_York

# Zodiac system (tropical | sidereal)
DEFAULT_ZODIAC_SYSTEM=tropical

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable planetary calculations
ENABLE_PLANETARY_CALCULATIONS=true

# Enable alchemical transformations
ENABLE_ALCHEMICAL_TRANSFORMATIONS=true

# Enable recipe recommendations
ENABLE_RECIPE_RECOMMENDATIONS=true

# Enable real-time updates
ENABLE_REALTIME_UPDATES=false

# ============================================================================
# PERFORMANCE & OPTIMIZATION
# ============================================================================

# Node.js memory limit (MB)
NODE_OPTIONS=--max-old-space-size=4096

# Enable compression
ENABLE_COMPRESSION=true

# Image optimization
NEXT_PUBLIC_IMAGE_OPTIMIZATION=true

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# --- PRIMARY: Resend (recommended) ---
# Sign up at https://resend.com, verify your domain (alchm.kitchen), and create an API key.
# DNS records required: see Resend dashboard for SPF, DKIM, and DMARC records to add in Namecheap.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Sender address — must match a verified domain in Resend
EMAIL_FROM_NAME=alchm.kitchen
EMAIL_FROM_ADDRESS=noreply@alchm.kitchen

# --- FALLBACK: SMTP / Nodemailer ---
# Only used if RESEND_API_KEY is not set.
# For Gmail: smtp.gmail.com:587 (use App Password, not regular password)
# For SendGrid: smtp.sendgrid.net:587
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password-here

# Email service notes:
# - Resend is the preferred provider (set RESEND_API_KEY)
# - SMTP is the fallback if Resend is not configured
# - Leave all email vars empty to disable email sending

# ============================================================================
# STRIPE PAYMENTS
# ============================================================================

# Stripe secret key (server-side only)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Stripe publishable key (exposed to client)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# Stripe webhook signing secret (from Stripe CLI or Dashboard)
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# Stripe Price ID for Premium tier (create in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PREMIUM_PRICE_ID=price_premium_id

# ============================================================================
# INSTACART INTEGRATION
# ============================================================================

# Instacart Developer Platform API Key
# Get yours at: https://www.instacart.com/developer
# Used by: /api/instacart/shopping-list — creates a shoppable grocery list
# on Instacart Marketplace from the meal planner grocery list.
# Leave empty to disable the "Order on Instacart" button.
INSTACART_API_KEY=

# ============================================================================
# RESTAURANT DISCOVERY
# ============================================================================

# Foursquare Places API v3 key
# Get yours at: https://foursquare.com/developers (10k calls/month free)
# Used by: /api/restaurants/search (profile search) and /api/restaurants/scored-search
#   (alchm-scored "Order it" discovery in the menu planner).
# Leave empty to disable restaurant search features.
FOURSQUARE_API_KEY=

# Google Places API (New) key
# Enable Nearby Search for /api/restaurants/discover.
GOOGLE_PLACES_API_KEY=

# Yelp Fusion API key
# Get yours at: https://fusion.yelp.com (500 calls/day free)
# Used by: /api/restaurants/yelp-search (alternate provider for "Order it" discovery).
# Leave empty to disable the Yelp-backed discovery route.
YELP_API_KEY=

# Tripadvisor Content API key
# Get a free key at: https://www.tripadvisor.com/developers (5,000 calls/month,
# credit card required). This is the preferred RATED source for the Best Match
# finder — it adds real ratings/reviews/price/cuisine that OpenStreetMap lacks.
# Used by: /api/restaurants/best-match (+ "Order it" discovery) when set;
# leave empty to fall back to keyless OpenStreetMap.
# NOTE: Tripadvisor's terms forbid caching rating data (the route fetches it
# fresh) and require showing their rating badge + "Powered by Tripadvisor" credit.
TRIPADVISOR_API_KEY=
# Optional: only if your TA key is REFERRER-restricted, set an allowed domain
# (otherwise configure the key for your server IP / leave unrestricted).
TRIPADVISOR_REFERER=
# Optional: how many top results to hydrate with details per search (quota-saver).
# Default 6, max 12. Each search costs 1 + N calls against the 5k/month quota.
TRIPADVISOR_DETAIL_LIMIT=6

# Stripe Connect / restaurant ordering
STRIPE_RESTAURANT_CONNECT_COUNTRY=US
STRIPE_RESTAURANT_SPLIT_MODE=separate_charges_and_transfers
STRIPE_RESTAURANT_PLATFORM_FEE_BPS=0
STRIPE_RESTAURANT_ORDER_PRICE_ID=

# Stablecoin Checkout (US businesses only; requires Stripe approval and the
# Crypto payment method enabled for the platform and connected restaurants).
# Customers see a crypto-only Checkout session and can choose supported tokens
# and networks, including USDC on Base. Stripe settles completed payments in USD.
NEXT_PUBLIC_STRIPE_RESTAURANT_CRYPTO_ENABLED=false

# Closed-loop ESMS restaurant redemption. Requires DATABASE_URL, a funded Stripe
# platform balance, and a Stripe-connected restaurant. The platform debits an
# equal Spirit/Essence/Matter/Substance basket and funds the restaurant transfer.
NEXT_PUBLIC_ESMS_RESTAURANT_PAYMENTS_ENABLED=false
# Published redemption value in whole cents per ESMS token. Keep this below the
# cheapest acquisition cost and account for all outstanding reward liability.
# This rate is also published to users at /rewards (read from the same value).
NEXT_PUBLIC_ESMS_RESTAURANT_CENTS_PER_TOKEN=1
# Daily ESMS food-redemption caps (server-enforced, UTC day). Tokens summed
# across all four axes. 0 = unlimited; unset falls back to the defaults below.
# Per-user default 5000 (=$50 at 1c); aggregate default 200000 (=$2000 at 1c).
ESMS_RESTAURANT_PER_USER_DAILY_CAP=5000
ESMS_RESTAURANT_AGGREGATE_DAILY_CAP=200000
# /api/cron/esms-reconciliation runs hourly and reuses CRON_SECRET (above) to
# cross-check token debits against Stripe transfers; operators resolve stuck
# orders at POST /api/admin/restaurants/settlement.

# On-chain ESMS promo gate. Controls whether the homepage advertises "On-Chain
# ESMS" / "claim it to your Base wallet". MUST stay false until the EsmsToken
# contract is actually deployed and verified on-chain (the agents app's
# ESMS_CONTRACT_ADDRESS) — otherwise the site promises a flow that does not work.
NEXT_PUBLIC_ESMS_ONCHAIN_ENABLED=false
# Daily ESMS food-redemption caps (server-enforced, UTC day). Tokens summed
# across all four axes. 0 = unlimited; unset falls back to the defaults below.
# Per-user default 5000 (=$50 at 1c); aggregate default 200000 (=$2000 at 1c).
ESMS_RESTAURANT_PER_USER_DAILY_CAP=5000
ESMS_RESTAURANT_AGGREGATE_DAILY_CAP=200000
# /api/cron/esms-reconciliation runs hourly and reuses CRON_SECRET (above) to
# cross-check token debits against Stripe transfers; operators resolve stuck
# orders at POST /api/admin/restaurants/settlement.

# POS / logistics integrations
DELIVERECT_API_URL=https://api.deliverect.com
DELIVERECT_API_KEY=
DELIVERECT_MOCK_MODE=false
LOGISTICS_API_URL=https://api.logistics-provider.com
LOGISTICS_API_KEY=
LOGISTICS_PROVIDER=doordash_drive
LOGISTICS_MOCK_MODE=false

# Build/runtime toggles
ENABLE_RECIPE_STATIC_PARAMS=false
NEXT_PUBLIC_PLANETARY_KINETICS_URL=

# ============================================================================
# CROSS-SITE UNIFICATION — Planetary Agents (agents.alchm.kitchen)
# ============================================================================

# Shared server-to-server secret gating the economy sync endpoints
# (/api/economy/balance sync read + /api/economy/sync-debit). MUST be the
# IDENTICAL value set on Planetary Agents (PA) for the wallet bridge to work.
ALCHM_KITCHEN_SYNC_SECRET=

# PA producer endpoint for the historical-agent feed (recipe_post / yield_claim).
# Fronted server-side by GET /api/feed/historical-agents. When UNSET, that route
# serves WTEN-internal data (historical agents + their recipe events). Set to the
# confirmed PA URL to source from PA instead (takes precedence; no code change
# required). Sent with Bearer INTERNAL_API_SECRET if set. yield_claim items only
# arrive once PA is wired (they're a cross-network, PA-owned event).
PA_HISTORICAL_FEED_URL=

# Agents-app base URL for the REVERSE cross-site session bridge. When a user is
# signed in only on the agents app (NextAuth v4 cookie next-auth.session-token),
# WTEN calls <AGENTS_BASE_URL>/api/auth/session to recognize them and resolve the
# matching WTEN user by email — so a Bazaar "Food" handoff doesn't force a second
# login. Must be the agents Next.js app host (NOT the api. backend). Fail-open:
# if unset, defaults to https://agents.alchm.kitchen.
AGENTS_BASE_URL=https://agents.alchm.kitchen

# Privy shared cross-site identity — the SAME Privy app on alchm.kitchen and
# agents.alchm.kitchen ⇒ same DID + same embedded Base wallet on both sites.
# Public app id (safe to expose); identical value on both repos.
NEXT_PUBLIC_PRIVY_APP_ID=cmi9t84qs00acl80dam2j8195
# Server secret from the Privy dashboard. NEVER expose client-side; identical on both repos.
PRIVY_APP_SECRET=
# NOTE: ESMS on-chain vars (NEXT_PUBLIC_ESMS_CHAIN / ESMS_CONTRACT_ADDRESS /
# PRIVY_MINTER_WALLET_ID) are PA-ONLY — WhatToEatNext needs none of them.

# ============================================================================
# RECIPE-NFT MINTING  (on-chain recipe provenance — OFF by default)
# ============================================================================
# The off-chain ESMS spend + alchemical-fingerprint commitment ship enabled; the
# on-chain mint stays OFF until ALL the gate vars below are set. Until then
# src/lib/recipe-nft/minter.ts records the ledger row as `pending_chain` and a
# backfill (scripts/backfill-recipe-token-ids.ts) mints it once the protocol is
# live. Deploy RecipeRegistry + AlchmRightsRegistry first — see docs/recipe-nft/DEPLOY.md.
#
# Chain to mint on. Unset or "base-sepolia" = testnet; "base" only for a
# deliberate mainnet cutover (which also needs BASE_RPC_URL instead of the sepolia one).
NEXT_PUBLIC_RECIPE_NFT_CHAIN=base-sepolia
# Master gate. Literal "true" enables minting — but only once the three addresses
# and the rights id below are all set; any other value keeps minting off.
NEXT_PUBLIC_RECIPE_NFT_ENABLED=false
# Deployed registry addresses, printed by DeployRecipeProtocol.s.sol. Must start with 0x.
NEXT_PUBLIC_RECIPE_REGISTRY_ADDRESS=
NEXT_PUBLIC_RIGHTS_REGISTRY_ADDRESS=
# Genesis rights id (bytes32) printed by the deploy. It folds in the work hash, so
# it changes on any redeploy / chain switch — re-read and re-set it each time.
NEXT_PUBLIC_ALCHM_RIGHTS_ID=
# Public URL where the license manifest (docs/recipe-nft/ALCHM-RECIPE-LICENSE-v1.md)
# is pinned; surfaced in the mint UI and must match the on-chain licenseURI.
NEXT_PUBLIC_ALCHM_LICENSE_URI=
# RPC for receipt waits + on-chain license reads (testnet default shown).
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
# SERVER-ONLY sponsor wallet that pays gas for backend-sponsored mints. Must be the
# rights holder or an authorized operator, and kept funded. NEVER commit a real
# key — set this only in the deployment secret store (Vercel), never in this file.
RECIPE_MINTER_PRIVATE_KEY=

# ============================================================================
# THIRD-PARTY SERVICES
# ============================================================================

# Analytics (Google Analytics, Plausible, etc.)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=alchm.kitchen

# ============================================================================
# PWA / SERVICE WORKER  (opt-in — off by default)
# ============================================================================
# The installable PWA + offline asset caching ship disabled. To turn them on,
# set BOTH flags to "true" and redeploy:
#   ENABLE_PWA             build-time: makes `next build` generate public/sw.js
#   NEXT_PUBLIC_ENABLE_PWA runtime:    lets the browser register /sw.js
# The service worker caches immutable /_next/static assets + images only — it
# never caches HTML or /api responses, so deploys stay fresh and auth/economy
# data always hits the network. Verify on a Vercel PREVIEW deploy before prod;
# a service worker persists in users' browsers.
# ENABLE_PWA=true
# NEXT_PUBLIC_ENABLE_PWA=true

# ============================================================================
# WEB PUSH  (dark by default — layered ON TOP of the PWA flags above)
# ============================================================================
# Device push notifications ship fully built but OFF. They require the PWA
# flags above AND the three gates below. Generate a VAPID keypair once with:
#   npx web-push generate-vapid-keys
# then paste the values here (VAPID_PUBLIC_KEY and NEXT_PUBLIC_VAPID_PUBLIC_KEY
# are the SAME value — the public key; the client needs the NEXT_PUBLIC_ copy
# for applicationServerKey).
#
#   WEB_PUSH_ENABLED       server kill switch: unset → every send path no-ops
#                          (subscriptions are still accepted so a later flip
#                          reaches devices that already opted in)
#   NEXT_PUBLIC_WEB_PUSH   client affordance: "1" shows the "Device
#                          notifications" toggle in the bell (still needs
#                          NEXT_PUBLIC_ENABLE_PWA=true + a registered SW)
#
# Push-eligible types: table_invite, table_going_live, comment_received,
# dm_message. reaction_received and agent_broadcast are permanently poll-only.
# Ship dark; flip on a Vercel PREVIEW with ENABLE_PWA=true first (iOS needs
# ≥16.4 + home-screen install). The 60s bell poll is the universal fallback.
# WEB_PUSH_ENABLED=true
# NEXT_PUBLIC_WEB_PUSH=1
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:hello@alchm.kitchen
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Enable debug mode
DEBUG=false

# Enable source maps in production
GENERATE_SOURCEMAP=false

# Hot reload
FAST_REFRESH=true

# ============================================================================
# DOCKER & DEPLOYMENT
# ============================================================================

# Container port
PORT=3000

# Health check endpoint
HEALTH_CHECK_PATH=/api/health

# Deployment platform (vercel | docker | kubernetes | standalone)
DEPLOYMENT_PLATFORM=docker

# ============================================================================
# NOTES
# ============================================================================
#
# 1. Never commit .env.local or .env.production to version control
# 2. Generate strong random secrets for JWT_SECRET
# 3. Update NEXT_PUBLIC_APP_URL to match your domain in production
# 4. Set appropriate log levels for each environment
# 5. Enable REDIS_URL if using caching
# 6. Configure CORS_ALLOWED_ORIGINS for your domains
# 7. Configure SMTP settings to enable onboarding emails
# 8. For Gmail: Use App Passwords (requires 2FA enabled)
# 9. Set INSTACART_API_KEY to enable "Order on Instacart" in the meal planner
#

# ============================================================================
# SpacetimeDB (v4.0 real-time layer) — all optional; unset = legacy paths
# ============================================================================
# WebSocket URI of the SpacetimeDB instance (Maincloud or self-hosted).
# Leave unset to disable the live layer entirely.
NEXT_PUBLIC_SPACETIME_URI=
# Database name the alchm_culinary module is published under.
NEXT_PUBLIC_SPACETIME_MODULE=alchm-culinary
# Per-surface flags ("1" to enable; anything else = legacy behavior):
NEXT_PUBLIC_SPACETIME_LIVE_CULINARY=   # browse surfaces merge live recipes
NEXT_PUBLIC_SPACETIME_LIVE_PLANNER=    # weekly plan write-mirror + sync badge
NEXT_PUBLIC_SPACETIME_LIVE_CART=       # two-way grocery cart sync
NEXT_PUBLIC_SPACETIME_LIVE_FEED=       # push feed events (poll = fallback)
NEXT_PUBLIC_SPACETIME_LIVE_COMMENSAL=  # live dinner-party lobby
# Seed ETL (scripts/spacetime/seedCulinary.ts) connection target:
SPACETIME_URI=ws://localhost:3000
SPACETIME_MODULE=alchm-culinary

# ── Privy server-wallet custody (chain operator, replaces raw keys) ─────────
# Wallet ids from scripts/provision-privy-server-wallets.ts --apply
PRIVY_MINTER_WALLET_ID=
PRIVY_REDEEMER_WALLET_ID=
# Required only if an authorization keypair is registered in the Privy Dashboard
PRIVY_AUTHORIZATION_PRIVATE_KEY=
# EsmsToken admin key — only needed by the provisioning script's role grants
ESMS_ADMIN_PRIVATE_KEY=
